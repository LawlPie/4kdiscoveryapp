# Copy to `.env` and adjust. docker-compose reads this automatically.

# ===== Scraper =====
# The scraper queries Platekompaniet's Algolia search backend (the same one its
# website uses) and filters strictly to 4K Ultra HD. Defaults work out of the box.
# Runs once a day at this local time (early morning = fresh overnight deals):
SCRAPE_HOUR=5
SCRAPE_MINUTE=0
SCRAPE_TIMEZONE=Europe/Oslo
# A routine container restart does NOT re-scrape; it only scrapes on startup when
# the stored data is older than this many hours (or empty):
SCRAPE_INTERVAL_HOURS=24
SCRAPE_ON_STARTUP=true
SCRAPE_FULL_CATALOGUE=true      # fetch ALL ~6500 4K titles (false = top-popular only)
SCRAPE_MAX_ITEMS=1000          # cap for top-popular mode only (ignored in full mode)
SCRAPE_ONLY_ON_OFFER=false     # set true to store only items on offer/campaign
SCRAPE_DELAY_SECONDS=1.5

# Override only if Platekompaniet rotates its public Algolia credentials:
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX=plate_prod_default_products
# ALGOLIA_4K_FILTER=format_media:4K Ultra HD

# ===== iMusic (second retailer, price comparison) =====
# Scrapes iMusic's 4K catalogue and matches discs to Platekompaniet by EAN.
SCRAPE_IMUSIC=true
# IMUSIC_4K_URL=https://imusic.co/exposure/13562/4k-uhd-movies
# IMUSIC_IMPERSONATE=chrome      # curl_cffi browser fingerprint (defeats 418 block)

# ===== Notifications =====
# Enable Discord by pasting a channel webhook URL:
DISCORD_WEBHOOK_URL=

# ...or enable Telegram instead (create a bot via @BotFather, get your chat id):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Watchlist alerts fire when a favourited item is genuinely discounted (current
# price below its original) and cheaper than the last alert — not on campaign-tag
# changes alone. Min discount off the original to alert (0.0 = any discount):
NOTIFY_MIN_DROP_PCT=0.0
# Cap alerts per scrape so a big watchlist can't flood your webhook:
NOTIFY_MAX_PER_RUN=25
