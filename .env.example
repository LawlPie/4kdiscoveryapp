# Copy to `.env` and adjust. docker-compose reads this automatically.

# ===== Scraper =====
SCRAPER_BASE_URL=https://www.platekompaniet.no/filmer-serier/4k-ultra-hd
SITE_ROOT=https://www.platekompaniet.no
SCRAPE_INTERVAL_HOURS=24
SCRAPE_ON_STARTUP=true
SCRAPE_DELAY_SECONDS=1.5
SCRAPE_MAX_PAGES=40

# ===== Notifications =====
# Enable Discord by pasting a channel webhook URL:
DISCORD_WEBHOOK_URL=

# ...or enable Telegram instead (create a bot via @BotFather, get your chat id):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Only notify when a watched item drops by at least this fraction (0.0 = any drop).
NOTIFY_MIN_DROP_PCT=0.0
